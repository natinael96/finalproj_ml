# Backend (FastAPI)
BP_MODEL_PATH=artifacts/model.joblib
# Optional. If set, clients must send x-api-key or ?api_key= for WebSockets.
BP_API_KEY=
BP_API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Set true to enable /ws/dashboard, /ws/ingest (ESP32 uses HTTP /esp32/ingest by default)
BP_WEBSOCKET_ENABLED=false
# ESP32 HTTP ingest: buffer this many samples before inference (default 2000 = 8 s @ 250 Hz)
# ESP32_PREDICTION_SAMPLES=2000
# ESP32_PREDICTION_FS_HZ=250
# ESP32_PREDICTION_WINDOW_S=8.0

# Supabase (for backend inserts)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Server-side owner for ESP32 DB rows (dashboard auth user UUID — ESP does not send this)
BP_DEFAULT_USER_ID=
# Optional session UUID for telemetry_windows / esp32_raw_batches
BP_DEFAULT_SESSION_ID=

# Dashboard (Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
NEXT_PUBLIC_BP_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_BP_DASHBOARD_WS_URL=ws://127.0.0.1:8000/ws/dashboard
# Set true to connect Live page to FastAPI /ws/dashboard (Supabase realtime still works when false)
NEXT_PUBLIC_BP_WEBSOCKET_ENABLED=false
# Match BP_API_KEY only for local/demo environments if you enabled it.
NEXT_PUBLIC_BP_API_KEY=
